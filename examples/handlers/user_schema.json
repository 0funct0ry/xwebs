{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "User Message",
  "type": "object",
  "properties": {
    "type": {
      "type": "string",
      "enum": ["query", "update", "delete"]
    },
    "id": {
      "type": "integer",
      "minimum": 1
    },
    "payload": {
      "type": "object"
    }
  },
  "required": ["type", "id"]
}
